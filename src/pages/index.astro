---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const lead = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			{
				lead && (
					<article class="lead">
						<span class="kicker">Issue No. 01 · Front Page</span>
						<h2 class="headline">
							<a href={`${base}/${lead.id}/`}>{lead.data.title}</a>
						</h2>
						<p class="byline">
							By <strong>조동필</strong> · <FormattedDate date={lead.data.pubDate} />
						</p>
						<p class="dek">{lead.data.description}</p>
						<p class="readmore">
							<a href={`${base}/${lead.id}/`}>Continue reading →</a>
						</p>
					</article>
				)
			}
			{
				rest.length > 0 && (
					<section class="more">
						<h3 class="section-label">Also in this issue</h3>
						<ul>
							{rest.map((post) => (
								<li>
									<a href={`${base}/${post.id}/`}>
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="title">{post.data.title}</span>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.lead {
		padding-top: 1rem;
	}
	.kicker {
		display: inline-block;
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		padding-bottom: 0.35rem;
		border-bottom: 1px solid #000;
		margin-bottom: 1.25rem;
	}
	.headline {
		font-family: var(--serif-display);
		font-weight: 900;
		font-size: clamp(2rem, 5vw, 2.8rem);
		line-height: 1.1;
		letter-spacing: -0.015em;
		margin: 0 0 0.75rem;
		border-top: 0;
		padding-top: 0;
	}
	.headline a {
		color: #000;
		text-decoration: none;
	}
	.headline a:hover {
		text-decoration: underline;
		text-underline-offset: 4px;
	}
	.byline {
		margin: 0 0 1.2rem;
		font-size: 0.9rem;
		color: #333;
	}
	.dek {
		font-size: 1.1rem;
		line-height: 1.6;
		color: #111;
		margin: 0 0 1.25rem;
	}
	.readmore a {
		font-style: italic;
		text-decoration: none;
		border-bottom: 1px solid #000;
	}
	.more {
		margin-top: 3.5rem;
		padding-top: 1.75rem;
		border-top: 3px double #000;
	}
	.section-label {
		font-family: var(--serif);
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		margin: 0 0 1.25rem;
		border-top: 0;
		padding-top: 0;
		font-weight: 700;
	}
	.more ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.more li {
		padding: 0.6rem 0;
		border-bottom: 1px solid #000;
	}
	.more li:last-child {
		border-bottom: 0;
	}
	.more a {
		display: flex;
		gap: 1rem;
		align-items: baseline;
		color: #000;
		text-decoration: none;
	}
	.more a:hover .title {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.more .date {
		font-size: 0.8rem;
		color: #555;
		white-space: nowrap;
		min-width: 7rem;
	}
	.more .title {
		font-family: var(--serif-display);
		font-size: 1.15rem;
		font-weight: 700;
	}
</style>
