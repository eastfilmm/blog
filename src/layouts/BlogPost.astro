---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHOR, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, keywords, faq } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'TechArticle',
	headline: title,
	description,
	author: {
		'@type': 'Person',
		name: AUTHOR.name,
		jobTitle: AUTHOR.jobTitle,
		affiliation: AUTHOR.affiliation,
		url: AUTHOR.url,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: Astro.site?.toString(),
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	inLanguage: 'ko',
	mainEntityOfPage: canonicalURL,
	url: canonicalURL,
	...(keywords ? { keywords } : {}),
};

const faqSchema =
	faq && faq.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faq.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: null;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<script
			type="application/ld+json"
			is:inline
			set:html={JSON.stringify(articleSchema)}
		/>
		{
			faqSchema && (
				<script
					type="application/ld+json"
					is:inline
					set:html={JSON.stringify(faqSchema)}
				/>
			)
		}
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="article-head">
					<p class="kicker">Feature · Frontend</p>
					<h1>{title}</h1>
					<p class="dek">{description}</p>
					<p class="byline">
						By <strong>{AUTHOR.name}</strong>
						<span class="sep">·</span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span class="sep">·</span>
									<span class="updated">Updated <FormattedDate date={updatedDate} /></span>
								</>
							)
						}
					</p>
					<hr class="rule" />
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.article-head {
		margin: 2rem 0 2.5rem;
	}
	.kicker {
		margin: 0 0 0.9rem;
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #000;
	}
	.article-head h1 {
		font-family: var(--serif-display);
		font-weight: 900;
		font-size: clamp(2.1rem, 5.5vw, 3.1rem);
		line-height: 1.08;
		letter-spacing: -0.018em;
		margin: 0 0 0.85rem;
	}
	.dek {
		font-size: 1.12rem;
		line-height: 1.55;
		color: #111;
		margin: 0 0 1.2rem;
		font-style: italic;
	}
	.byline {
		font-size: 0.88rem;
		color: #333;
		margin: 0 0 1.25rem;
	}
	.byline strong {
		color: #000;
	}
	.sep {
		margin: 0 0.35rem;
	}
	.updated {
		font-style: italic;
	}
	.rule {
		border: 0;
		border-top: 3px double #000;
		margin: 1rem 0 0;
	}
	.prose :global(p):first-of-type::first-letter {
		font-family: var(--serif-display);
		font-size: 3.2em;
		font-weight: 900;
		line-height: 0.9;
		float: left;
		padding: 0.2rem 0.55rem 0 0;
		margin-top: 0.2rem;
	}
</style>
