---
import { AUTHOR } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<p>
		© {year} {AUTHOR.name} · <a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a>
	</p>
</footer>

<style>
	.site-footer {
		max-width: 680px;
		margin: 2.5rem auto 2rem;
		padding: 1rem 1.25rem 0;
		border-top: 1px solid #e5e5e5;
		font-size: 0.82rem;
		color: #777;
	}
	.site-footer p {
		margin: 0;
	}
	.site-footer a {
		color: #777;
	}
</style>
